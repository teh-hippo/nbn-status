# NBN Status Monitor - Environment Configuration
# Copy this to .env and fill in your values.

# Addresses to monitor (JSON array)
# Fields: label, loc_id, poll (currently unused), notify (triggers ntfy), compare (neighbour check)
# Find LOC IDs at: https://places.nbnco.net.au/places/v1/autocomplete?query=YOUR+ADDRESS
NBN_ADDRESSES='[
  {"label": "Home",         "loc_id": "LOC000000000001", "poll": true,  "notify": true},
  {"label": "Neighbour",    "loc_id": "LOC000000000002", "poll": true,  "notify": false, "compare": true},
  {"label": "Nearby A",     "loc_id": "LOC000000000003", "poll": false, "notify": false},
  {"label": "Nearby B",     "loc_id": "LOC000000000004", "poll": false, "notify": false}
]'

# ntfy configuration
NTFY_TOPIC=your-topic-name
NTFY_SERVER=https://ntfy.sh

# Status page URL (included in ntfy action button)
STATUS_PAGE_URL=http://localhost:8000

# State file location (default: state.json in working directory)
# NBN_STATE_FILE=state.json
